{
  "title": "ATF Validator",
  "uid": "atf-validator",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput per STA",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"throughput\")\n  |> filter(fn: (r) => r._field == \"throughput_mbps\")\n  |> group(columns: [\"agent_id\", \"run_id\"])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Sync Offset per STA (ms)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"run_summary\")\n  |> filter(fn: (r) => r._field == \"sync_offset_ms\")\n  |> last()"
        }
      ]
    },
    {
      "id": 3,
      "title": "Mean Throughput per STA (last run)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"run_summary\")\n  |> filter(fn: (r) => r._field == \"mean_mbps\")\n  |> last()"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
