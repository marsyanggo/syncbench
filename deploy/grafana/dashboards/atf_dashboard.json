{
  "title": "ATF Validator",
  "uid": "atf-validator",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput per STA",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"throughput\")\n  |> filter(fn: (r) => r._field == \"throughput_mbps\")\n  |> group(columns: [\"agent_id\", \"run_id\"])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Sync Offset per STA (ms)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r._measurement == \"run_summary\")\n  |> filter(fn: (r) => r._field == \"sync_offset_ms\")\n  |> group(columns: [\"agent_id\"])\n  |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "AP Airtime per STA (TX %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"ap_airtime\")\n  |> filter(fn: (r) => r._field == \"tx_pct\")\n  |> group(columns: [\"agent_id\"])"
        }
      ]
    },
    {
      "id": 3,
      "title": "Live Avg Throughput per STA",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "textMode": "value_and_name",
        "colorMode": "value",
        "justifyMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "decimals": 1,
          "displayName": "${__field.labels.agent_id}",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "atf-influxdb" },
          "query": "from(bucket: \"atf_metrics\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r._measurement == \"throughput\")\n  |> filter(fn: (r) => r._field == \"throughput_mbps\")\n  |> filter(fn: (r) => exists r.agent_id and r.agent_id != \"\")\n  |> group(columns: [\"agent_id\", \"run_id\"])\n  |> mean()\n  |> group(columns: [\"agent_id\"])\n  |> last(column: \"_value\")\n  |> keep(columns: [\"agent_id\", \"_value\"])"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
